{
    "headers": [
        {
            "source": "/(.*)",
            "headers": [
                {
                    "key": "X-Robots-Tag",
                    "value": "all"
                }
            ]
        }
    ],
    "rewrites": [
        {
            "source": "/api/deezer/(.*)",
            "destination": "/api/deezer"
        },
        {
            "source": "/((?!api/).*)",
            "destination": "/index.html"
        }
    ]
}